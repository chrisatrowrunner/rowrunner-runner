# RowRunner Runner — environment configuration
#
# Copy to `.env` and fill in. Vite only exposes vars prefixed with VITE_ to the
# client. The anon key is safe to expose (it's a public, RLS-gated client key);
# never put the service_role key here.
#
# Order of precedence in src/lib/orders.ts:
#   1. Supabase   — used when the two VITE_SUPABASE_* vars below are set
#   2. Edge server (VITE_EDGE_URL, default http://localhost:4000)
#   3. Local mock — set VITE_USE_MOCK=1

# ── Supabase (the shared backend) ────────────────────────────
# Dashboard ▸ Project Settings ▸ API:
#   VITE_SUPABASE_URL      = "Project URL"
#   VITE_SUPABASE_ANON_KEY = "Project API keys ▸ anon public"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Fallbacks (ignored when Supabase is set) ─────────────────
# VITE_EDGE_URL=http://localhost:4000
# VITE_USE_MOCK=1

# Which venue this build serves
VITE_VENUE_ID=nyc-tech-week
